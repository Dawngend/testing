# ==========================================
# 🚀 Runtime Terrors: Hackathon Configuration
# ==========================================

# --- 1. Supabase (Database & Auth) ---

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# --- 2. Groq API (For Llama 3.3 & Fast Inference) ---
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- 3. Qwen API (For Deep Reasoning & Verification) ---

QWEN_API_KEY=your_qwen_api_key_here

# --- 4. Optional: Local Paths (For OCR/Extraction) ---
# If Tesseract is installed in a custom path, update this.
# Otherwise, leave it or ensure 'tesseract' is in your system PATH.
TESSERACT_CMD=tesseract

# (Optional) Gemini API Key if using multi-AI
GEMINI_API_KEY=your_key_here
